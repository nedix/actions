{
  baseBranches: [
    "main",
  ],
  enabledManagers: [
    "custom.regex",
    "github-actions",
  ],
  customManagers: [
  ],
  packageRules: [
    {
      description: "Customize commit and pull request titles",
      matchPackagePatterns: [".*"],
      commitMessageAction: "Update dependency",
    },
    {
      description: "Disable grouping for all dependencies",
      matchPackagePatterns: [".*"],
      groupName: null,
    },
  ],
}
